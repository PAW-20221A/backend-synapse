APP_ENV=development
API_HOST=0.0.0.0
API_PORT=8000

# CORS (comma-separated; add Vercel URL after deploy)
CORS_ORIGINS=http://localhost:5173

# Database — use DATABASE_URL (Neon) in production, or POSTGRES_* locally
DATABASE_URL=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# JWT
SECRET_KEY=
ALGORITHM=
ACCESS_TOKEN_EXPIRE_MINUTES=

# Transcript API
TRANSCRIPT_API_BASE_URL=https://transcriptapi.com/api/v2
TRANSCRIPT_API_KEY=

# LLM (use one)
OPENAI_API_KEY=
# GROQ_API_KEY=
